{
  "name": "apple-text-workspace",
  "private": true,
  "description": "Workspace for Apple Text skills, Claude plugin packaging, MCP server, docs, and validation tooling",
  "type": "module",
  "scripts": {
    "setup": "python3 tooling/scripts/dev/bootstrap_dev.py",
    "setup:all": "bash tooling/scripts/workflows/setup_all.sh",
    "hooks:install": "python3 tooling/scripts/dev/install_git_hooks.py",
    "build:all": "bash tooling/scripts/workflows/build_all.sh",
    "preflight": "npm run check && npm run docs:build",
    "merge:check": "npm run preflight",
    "mcp:annotations:generate": "python3 tooling/scripts/mcp/generate_mcp_annotations.py",
    "mcp:annotations:check": "python3 tooling/scripts/mcp/generate_mcp_annotations.py --check",
    "mcp:build": "npm --prefix mcp-server run build",
    "mcp:bundle": "npm --prefix mcp-server run build:bundle",
    "mcp:generate": "python3 tooling/scripts/mcp/generate_mcp_annotations.py && python3 tooling/scripts/mcp/generate_mcp_bundle.py",
    "mcp:check": "python3 tooling/scripts/mcp/generate_mcp_annotations.py --check && python3 tooling/scripts/mcp/generate_mcp_bundle.py --check",
    "mcp:pack:check": "npm --prefix mcp-server run pack:check",
    "mcp:smoke": "npm --prefix mcp-server run smoke",
    "mcp:smoke:dev": "npm --prefix mcp-server run smoke:dev",
    "mcp:pack:dry-run": "npm --prefix mcp-server run pack:dry-run",
    "mcp:publish:dry-run": "npm --prefix mcp-server run publish:dry-run",
    "mcp:start": "npm --prefix mcp-server run start:dev",
    "lint": "npm run lint:repo && npm run descriptions:lint",
    "lint:repo": "python3 tooling/scripts/quality/lint_repo.py",
    "descriptions:lint": "python3 tooling/scripts/quality/evaluate_skill_descriptions.py",
    "descriptions:dataset": "python3 tooling/scripts/quality/evaluate_skill_descriptions.py --dataset tooling/evals/description-triggers.json",
    "test": "PYTHONPATH=tooling python3 -m unittest discover -s tooling/tests",
    "agents:build": "node scripts/build-agents.mjs",
    "agents:check": "node scripts/build-agents.mjs --check",
    "check": "npm run lint && npm run agents:check && npm run docs:check && python3 tooling/scripts/quality/validate_plugin.py && python3 tooling/scripts/mcp/generate_mcp_annotations.py --check && python3 tooling/scripts/mcp/generate_mcp_bundle.py --check && npm run mcp:bundle && npm run mcp:smoke && npm run mcp:pack:check && npm run descriptions:dataset && npm run test",
    "release:check": "npm run preflight",
    "skills:freshness": "python3 tooling/scripts/quality/skill_freshness.py",
    "version:set": "python3 tooling/scripts/release/set_version.py",
    "release": "bash tooling/scripts/release/release.sh",
    "docs:generate": "python3 tooling/scripts/docs/generate_docs.py",
    "docs:check": "python3 tooling/scripts/docs/generate_docs.py --check && python3 tooling/scripts/docs/validate_doc_links.py",
    "docs:dev": "python3 tooling/scripts/docs/generate_docs.py && astro dev --root docs",
    "docs:build": "python3 tooling/scripts/docs/generate_docs.py && astro build --root docs",
    "docs:preview": "astro preview --root docs"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.38.0",
    "astro": "^6.0.0"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "starlight-theme-black": "^0.6.0"
  }
}
