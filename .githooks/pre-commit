#!/bin/sh

# Pre-commit: regenerate derived files, stage them, run fast checks.
# Full validation runs in pre-push.

set -eu

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

# ── Regenerate derived files from source skills ──────────────────────
node scripts/build-agents.mjs
python3 tooling/scripts/docs/generate_docs.py
python3 tooling/scripts/mcp/generate_mcp_annotations.py
python3 tooling/scripts/mcp/generate_mcp_bundle.py

# ── Stage regenerated files ──────────────────────────────────────────
git add \
  README.md \
  agents/textkit-reference.md \
  agents/editor-reference.md \
  agents/rich-text-reference.md \
  agents/platform-reference.md \
  mcp-server/skill-annotations.json \
  mcp-server/bundle.json \
  docs/src/content/docs

# ── Fast checks only (~2s) ───────────────────────────────────────────
node scripts/build-agents.mjs --check
